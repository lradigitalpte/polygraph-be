# Application settings
HOST=0.0.0.0
PORT=8080
GIN_MODE=release
LOG_LEVEL=production

# Database (Railway Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Neon Auth — JWKS endpoint for JWT verification (required)
NEON_JWKS_URL=https://your-neon-auth-host/.well-known/jwks.json

# Public URLs (used in emails, form links, and CORS)
APP_PUBLIC_URL=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Comma-separated extra browser origins allowed by CORS (optional if FRONTEND_URL is set)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# Email (SMTP) for form links and payment reminders
FROM_ADDRESS=noreply@yourdomain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional S3 document storage (falls back to local uploads/ if unset)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET=

# Legacy / unused in current stack (safe to omit)
# JWT_SECRET=
# GO_BETTER_AUTH_BASE_URL=
# GO_BETTER_AUTH_SECRET=
# GO_BETTER_AUTH_DATABASE_URL=
# GRPC_PORT=50051
